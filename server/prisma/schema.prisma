generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  address   String
  password  String
  role      String   @default("user")
  photo     String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
